@model OnlineRestaurantApp.Components.Order
@using System.Linq

@{
    ViewData["Title"] = "Order Success";
    Layout = "~/Views/Shared/_PaymentLayout.cshtml";
}

@{
    // Flags from controller
    bool paid = ViewBag.Paid is bool pb && pb;
    bool isDelivered = ViewBag.IsDelivered is bool b && b;
    double? minutesRemaining = ViewBag.MinutesRemaining as double?;
    var expectedOnText = ViewBag.ExpectedOn as string;
    var assignedOnText = ViewBag.AssignedOn as string;
}

<div class="mb-2">
    @if (paid)
    {
        if (isDelivered)
        {
            <span id="deliveryBadge" class="badge bg-success">Delivered</span>
        }
        else if (minutesRemaining.HasValue)
        {
            <span id="deliveryBadge" class="badge bg-info text-dark">
                Arriving in ~@minutesRemaining.Value min
            </span>
        }
    }
    else
    {
        <span class="badge bg-warning text-dark">Payment Pending</span>
    }
</div>

@if (Model.Delivery?.Employee != null && paid)
{
    <div class="card mb-3">
        <div class="card-header fw-semibold">Delivery Details</div>
        <div class="card-body">
            <div><b>Delivery Partner:</b> @Model.Delivery.Employee.FullName</div>

            @if (!string.IsNullOrWhiteSpace(Model.Delivery.Employee.Phone))
            {
                <div><b>Phone:</b> @Model.Delivery.Employee.Phone</div>
            }

            <div><b>Status:</b> <span id="deliveryStatusText">@Model.Delivery.DeliveryStatus</span></div>

            @if (Model.Delivery.AssignedOn != null || Model.Delivery.ExpectedOn != null)
            {
                <div class="small text-muted mt-1">
                    @if (!string.IsNullOrWhiteSpace(assignedOnText))
                    {
                        <div><b>Assigned On:</b> @assignedOnText</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(expectedOnText))
                    {
                        <div><b>Expected By:</b> @expectedOnText</div>
                    }
                </div>
            }

            @if (Model.Delivery.Address != null)
            {
                <hr />
                <div class="fw-semibold mb-1">Delivery Address</div>
                <div>
                    @Model.Delivery.Address.AddressLine1
                    @if (!string.IsNullOrWhiteSpace(Model.Delivery.Address.AddressLine2))
                    {
                        <span>, @Model.Delivery.Address.AddressLine2</span>
                    }
                    <br />
                    @Model.Delivery.Address.City, @Model.Delivery.Address.State - @Model.Delivery.Address.Pincode
                </div>
            }
        </div>
    </div>
}
else if (!paid)
{
    <div class="alert alert-warning mb-3">
        Payment is not completed yet, so delivery is not assigned.
    </div>
}
else
{
    <div class="alert alert-warning mb-3">
        Delivery partner not assigned yet.
    </div>
}

<div class="container mt-4">
    @if (paid)
    {
        <div class="alert alert-success">
            <h4 class="mb-1">✅ Payment Done &amp; Order Placed Successfully!</h4>
            <div>Order ID: <b>@Model.OrderId</b></div>
            <div>Date: @Model.OrderDate</div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h4 class="mb-1">⚠️ Payment Pending</h4>
            <div>Order ID: <b>@Model.OrderId</b></div>
            <div class="mt-2">Your payment has not been completed. Please complete your payment to place the order.</div>
            <a class="btn btn-primary mt-2" href="/payment/start?orderId=@Model.OrderId">Complete Payment</a>
        </div>
    }

    <div class="card">
        <div class="card-header fw-semibold">Order Items</div>
        <div class="card-body p-0">
            @if (Model.orderDetailsItems == null || !Model.orderDetailsItems.Any())
            {
                <div class="p-3 text-muted">No items found.</div>
            }
            else
            {
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.orderDetailsItems)
                        {
                            <tr>
                                <td>@d.ItemName</td>
                                <td class="text-end">₹@d.Price</td>
                                <td class="text-end">@d.Quantity</td>
                                <td class="text-end">₹@d.ItemAmount</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end">Total</th>
                            <th class="text-end">₹@Model.OrderAmount</th>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <a class="btn btn-primary" href="/FoodItems/Browse">Continue Shopping</a>
        @if (!paid)
        {
            <a class="btn btn-outline-success" href="/payment/start?orderId=@Model.OrderId">Pay Now</a>
        }
    </div>
</div>

@section Scripts {
    @if (paid)
    {
        <script>
            (function () {
                const isDelivered = @((isDelivered ? "true" : "false"));
                const minutes = @((minutesRemaining.HasValue ? Math.Ceiling(minutesRemaining.Value) : 0));
                if (isDelivered || minutes <= 0) return;

                const badge = document.getElementById('deliveryBadge');
                const statusText = document.querySelector('#deliveryStatusText'); // exists when delivery details section renders

                // countdown in seconds
                let remaining = minutes * 60;

                function tick() {
                    remaining--;
                    if (remaining <= 0) {
                        // Flip UI only; server has 'lazy flip' or background service for persistence
                        if (badge) {
                            badge.className = 'badge bg-success';
                            badge.textContent = 'Delivered';
                        }
                        if (statusText) statusText.textContent = 'Delivered';
                        clearInterval(timer);
                    }
                }
                const timer = setInterval(tick, 1000);
            })();
        </script>
    }
}
``