@using OnlineRestaurantApp.Dal

@using Microsoft.AspNetCore.Http

@inject OnlineRestaurantDbContext Db

@inject IHttpContextAccessor HttpContextAccessor

@{

    // Read session to decide which auth links to show

    var session = HttpContextAccessor.HttpContext?.Session;
    var loggedInEmail = session?.GetString("loggedinuser"); // this is Email
    var isLoggedIn = !string.IsNullOrEmpty(loggedInEmail);
    // Try to read name from session (optional), else load from DB (fallback)
    var loggedInName = session?.GetString("loggedinname");
    if (isLoggedIn && string.IsNullOrWhiteSpace(loggedInName))
    {
        var u = Db.users.FirstOrDefault(x => x.Email == loggedInEmail);
        if (u != null)
        {
            // Use first name as display name (safe)
            loggedInName = string.IsNullOrWhiteSpace(u.UserFirstName) ? loggedInEmail : u.UserFirstName;
        }
        else
        {
            loggedInName = loggedInEmail;

        }

    }

    // Load active categories with valid image paths for the strip

    var categoriesForLayout = Db.categories

        .Where(c => c.CategoryStatus)

        .OrderBy(c => c.CategoryName)

        .Select(c => new

        {

            Id = c.CategoryId,

            Name = c.CategoryName ?? "",

            Img = string.IsNullOrWhiteSpace(c.CategoryImagePath)

                ? "/images/categories/placeholder.jpg"

                : c.CategoryImagePath

        })

        .Take(24)

        .ToList();

}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SajikRestaurantApp</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OnlineRestaurantApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm sticky-top">
            <div class="container-fluid px-3">

                <!-- Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2 fw-semibold"
                   asp-controller="FoodItems" asp-action="Browse">
                    <i class="bi bi-shop-window text-warning fs-5"></i>
                    <span>Sajik</span>
                    <span class="d-none d-sm-inline">Online Restaurant</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- Center Search -->
                    <form class="navbar-search d-flex flex-grow-1 my-2 my-lg-0 mx-lg-3"
                          method="get"
                          asp-controller="FoodItems"
                          asp-action="Browse"
                          style="max-width: 760px;">

                        <div class="input-group input-group-sm w-100">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>

                            <input class="form-control"
                                   type="search"
                                   name="search"
                                   placeholder="Search dishes, cuisines, restaurants…"
                                   aria-label="Search" />

                            <select name="diet" class="form-select" style="max-width: 160px;">

                                @{

                                    var selectedDiet = (ViewBag.Diet as string)?.ToLowerInvariant() ?? "";

                                }
                                <option value="" selected="@(string.IsNullOrEmpty(selectedDiet))">All</option>
                                <option value="veg" selected="@(selectedDiet == "veg")">Veg</option>
                                <option value="nonveg" selected="@(selectedDiet == "nonveg")">Non-Veg</option>
                            </select>

                            <button class="btn btn-outline-light" type="submit">

                                Search
                            </button>
                        </div>
                    </form>

                    <!-- Right Side -->
                    <ul class="navbar-nav ms-auto flex-lg-row align-items-lg-center gap-lg-2">

                        @if (isLoggedIn)

                        {
                            <!-- Feedback -->
                            <li class="nav-item">
                                <a class="btn btn-sm feedback-btn px-3"
                                   asp-controller="Feedback"
                                   asp-action="Create"
                                   title="Share your feedback">
                                    <i class="bi bi-chat-dots me-1"></i>
                                    Feedback
                                </a>
                            </li>

                            <!-- Cart -->
                            <li class="nav-item">
                                <a class="nav-link position-relative text-white"
                                   asp-controller="Cart"
                                   asp-action="Items"
                                   title="View Cart">
                                    <i class="bi bi-cart3 fs-5"></i>

                                    <span id="cartBadgeCount"
                                          class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">

                                        0
                                    </span>
                                </a>
                            </li>

                            <!-- Profile dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white d-flex align-items-center gap-2"
                                   href="#"
                                   id="profileDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="bi bi-person-circle fs-5"></i>
                                    <span class="d-none d-lg-inline text-nowrap">My Account</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end p-0 shadow border-0"
                                    aria-labelledby="profileDropdown"
                                    style="min-width: 330px; border-radius: 14px; overflow:hidden;">

                                    <!-- Header card -->
                                    <li class="p-3"
                                        style="background: linear-gradient(135deg, #0F2027, #203A43, #2C5364);">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-white text-dark rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width:48px;height:48px;">
                                                <i class="bi bi-person-fill fs-4"></i>
                                            </div>
                                            <div class="text-white">
                                                <div class="fw-semibold">@loggedInName</div>
                                                <div class="small text-white-50">@loggedInEmail</div>
                                            </div>
                                        </div>
                                    </li>

                                    <!-- Links -->
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="Profile"
                                           asp-action="MyOrders">
                                            <i class="bi bi-bag-check me-2"></i> My Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="Profile"
                                           asp-action="MyPayments">
                                            <i class="bi bi-credit-card me-2"></i> My Payments
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="Profile"
                                           asp-action="DeliveryAddress">
                                            <i class="bi bi-geo-alt me-2"></i> Delivery Address
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="User"
                                           asp-action="ChangePassword">
                                            <i class="bi bi-chat-dots"></i> Reset Password
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider m-0" /></li>
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="Profile"
                                           asp-action="MyFeedbacks">
                                            <i class="bi bi-chat-dots"></i> My Feedbacks
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 profile-dd-item"
                                           asp-controller="User"
                                           asp-action="ChangePassword">
                                            <i class="bi bi-chat-dots"></i> Change Password
                                        </a>
                                    </li>
                                    <li class="p-2">
                                        <a class="btn btn-outline-danger w-100"
                                           asp-controller="User"
                                           asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>

                        }

                        else

                        {
                            <li class="nav-item">
                                <a class="btn btn-sm feedback-btn px-3"
                                   asp-controller="Feedback"
                                   asp-action="Create"
                                   title="Share your feedback">
                                    <i class="bi bi-chat-dots me-1"></i>
                                    Feedback
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm text-nowrap"
                                   asp-controller="User"
                                   asp-action="Login">

                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm text-nowrap"
                                   asp-controller="User"
                                   asp-action="Register">

                                    Register
                                </a>
                            </li>

                        }

                    </ul>
                </div>
            </div>
        </nav>

        <partial name="DisplaySlider" />
    </header>

    <div class="container">
        <main role="main" class="pb-3">

            @RenderBody()
        </main>
    </div>

    <footer class="text-light mt-5"
            style="background: linear-gradient(135deg, #0F2027, #203A43, #2C5364);">
        <div class="container py-4">
            <div class="row gy-4">

                <!-- Brand -->
                <div class="col-md-4">
                    <h5 class="fw-bold mb-2">Sajik Restaurant</h5>
                    <p class="small text-white-50 mb-0">

                        Delicious food delivered with care. Browse categories, search dishes, and order easily.
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-6 col-md-2">
                    <h6 class="fw-semibold mb-2">Quick Links</h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-1">
                            <a class="text-decoration-none text-white-50 hover-footer"
                               asp-controller="FoodItems" asp-action="Browse">

                                Browse
                            </a>
                        </li>
                        <li class="mb-1">
                            <a class="text-decoration-none text-white-50 hover-footer"
                               asp-controller="User" asp-action="Login">

                                Login
                            </a>
                        </li>
                        <li>
                            <a class="text-decoration-none text-white-50 hover-footer"
                               asp-controller="User" asp-action="Register">

                                Register
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Categories (Dynamic Links - uses your categoriesForLayout + same routing) -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-semibold mb-2">Categories</h6>

                    @if (categoriesForLayout != null && categoriesForLayout.Any())

                    {
                        <ul class="list-unstyled small mb-0">

                            @foreach (var c in categoriesForLayout.Take(6))

                            {
                                <li class="mb-1">
                                    <a class="text-decoration-none text-white-50 hover-footer"
                                       asp-controller="FoodItems"
                                       asp-action="Browse"
                                       asp-route-categoryId="@c.Id">

                                        @c.Name
                                    </a>
                                </li>

                            }
                        </ul>

                        @* Optional: show "View all" if you have more than 6 *@

                        @if (categoriesForLayout.Count > 6)

                        {
                            <div class="mt-2">
                                <a class="text-decoration-none text-white hover-footer fw-semibold small"
                                   asp-controller="FoodItems" asp-action="Browse">

                                    View all →
                                </a>
                            </div>

                        }

                    }

                    else

                    {
                        <div class="small text-white-50">No categories available.</div>

                    }
                </div>

                <!-- Contact -->
                <div class="col-md-3">
                    <h6 class="fw-semibold mb-2">Contact</h6>
                    <ul class="list-unstyled small text-white-50 mb-0">
                        <li class="mb-1">Email: support@sajikrestaurant.com</li>
                        <li class="mb-1">Phone: +91 98765 43210</li>
                        <li>Location: Chennai, Tamil Nadu</li>
                    </ul>
                </div>

            </div>

            <hr class="border-light opacity-25 my-4" />

            <div style="color:#ffd369;">
                © @DateTime.UtcNow.Year - Sajik Restaurant. All rights reserved.
            </div>
        </div>
    </footer>


    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>

        async function getCartCount() {

            try {

                const r = await fetch('/cart/count', { cache: 'no-store' });

                if (!r.ok) return 0;

                const j = await r.json();

                return j?.ok ? (j.count || 0) : 0;

            } catch {

                return 0;

            }

        }


        function updateNavbarCartBadge(count) {
            const navBadge = document.getElementById('cartBadgeCount');
            if (!navBadge) return;
            navBadge.textContent = count || 0;

            // Optional: hide when empty
            // navBadge.style.visibility = (count > 0 ? 'visible' : 'hidden');
          }

          

          async function refreshCartBadges() {
            const count = await getCartCount();
            updateNavbarCartBadge(count);
            updateCheckoutFab(count);
          }

          // On initial load
          document.addEventListener('DOMContentLoaded', refreshCartBadges);

          // Keep badges in sync when pages fire 'cart:changed'
          window.addEventListener('cart:changed', (e) => {
            const count = e?.detail?.count ?? null;
            if (typeof count === 'number') {
              // If event carries count, use it directly
              updateNavbarCartBadge(count);
              updateCheckoutFab(count);
            } else {
              // Otherwise re-fetch from server
              refreshCartBadges();
            }
          });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
