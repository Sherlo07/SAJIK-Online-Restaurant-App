@using System
@using System.Collections.Generic
@using System.Linq
@model List<OnlineRestaurantApp.Components.FoodItem>

@{
    ViewData["Title"] = "My Cart";
    Layout = "~/Views/Shared/_PaymentLayout.cshtml";
    var qtyMap = ViewBag.CartQty is Dictionary<int, int> d
        ? d
        : new Dictionary<int, int>();

    decimal totalMrp = 0m;
    decimal totalSelling = 0m;
    decimal totalDiscount = 0m;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <h4 class="mb-3">Cart Items</h4>

            @if (Model == null || Model.Count == 0 || qtyMap.Count == 0)
            {
                <div class="alert alert-info">Your cart is empty.</div>
                <a class="btn btn-dark" asp-controller="FoodItems" asp-action="Browse">Browse Items</a>
            }
            else
            {
                foreach (var item in Model)
                {
                    var qty = qtyMap.ContainsKey(item.ItemId) ? qtyMap[item.ItemId] : 0;
                    if (qty <= 0) { continue; }

                    decimal mrp = item.ActualPrice;
                    decimal selling = item.SellingPrice > 0 ? item.SellingPrice : item.ActualPrice;

                    decimal discountPerUnit = mrp > selling ? (mrp - selling) : 0m;
                    decimal discountTotal = discountPerUnit * qty;
                    decimal lineTotal = selling * qty;

                    totalMrp += mrp * qty;
                    totalSelling += lineTotal;
                    totalDiscount += discountTotal;

                    var discountPercent = (mrp > 0m && mrp > selling)
                    ? Math.Round(((mrp - selling) / mrp) * 100m, 0)
                    : 0m;

                    var imgPath = string.IsNullOrWhiteSpace(item.ItemImagePath)
                    ? "/images/placeholder.png"
                    : item.ItemImagePath;

                    <div class="card mb-3 shadow-sm">
                        <div class="card-body d-flex gap-3 align-items-center">
                            <img src="@Url.Content(imgPath)"
                                 class="rounded"
                                 style="width:90px;height:90px;object-fit:cover;" />

                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@item.ItemName</h6>

                                        <div class="small text-muted">
                                            <span class="text-decoration-line-through me-2">₹@mrp</span>
                                            <span class="fw-semibold text-dark">₹@selling</span>

                                            @if (discountPercent > 0)
                                            {
                                                <span class="badge bg-success ms-2">@discountPercent% OFF</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <div class="fw-bold">₹@lineTotal</div>
                                        @if (discountTotal > 0)
                                        {
                                            <small class="text-success">Saved ₹@discountTotal</small>
                                        }
                                    </div>
                                </div>

                                <div class="mt-3 d-flex align-items-center gap-2">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            onclick="changeQty(@item.ItemId, @(qty - 1))">
                                        −
                                    </button>

                                    <span class="badge bg-dark">Qty: @qty</span>

                                    <button class="btn btn-outline-secondary btn-sm"
                                            onclick="changeQty(@item.ItemId, @(qty + 1))">
                                        +
                                    </button>

                                    <button class="btn btn-outline-danger btn-sm ms-2"
                                            onclick="changeQty(@item.ItemId, 0)">
                                        Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- BILL -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top:90px;">
                <div class="card-body">
                    <h5 class="mb-3">Bill Details</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (MRP)</span>
                        <span>₹@totalMrp</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Discount</span>
                        <span class="text-success">- ₹@totalDiscount</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between fw-bold fs-5">
                        <span>To Pay</span>
                        <span>₹@totalSelling</span>
                    </div>

                    <a class="btn btn-success w-100 mt-3" href="/cart/checkout">
                        Checkout
                    </a>
                    <a class="btn btn-dark mt-2" asp-controller="FoodItems" asp-action="Browse">Browse Items</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function changeQty(itemId, qty) {
            const res = await fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId, qty })
            });

            if (res.status === 401) {
                const j = await res.json();
                if (j.needLogin && j.loginUrl) window.location.href = j.loginUrl;
                return;
            }

            if (!res.ok) return;

            const j = await res.json();
            if (j.ok) {
                window.dispatchEvent(new CustomEvent('cart:changed', { detail: { count: j.count } }));
                location.reload();
            }
        }
    </script>
}