@using System
@using System.Collections.Generic
@using System.Linq
@model List<OnlineRestaurantApp.Components.FoodItem>

@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_PaymentLayout.cshtml";
    // Quantity map from controller: ViewBag.CartQty = cart.ToDictionary(...)
    var qtyMap = ViewBag.CartQty as Dictionary<int, int> ?? new Dictionary<int, int>();

    decimal totalMrp = 0m;
    decimal totalSelling = 0m;
    decimal totalDiscount = 0m;
}

<div class="container mt-4">
    <div class="row">

        <!-- LEFT: ORDER ITEMS -->
        <div class="col-lg-8">
            <h4 class="mb-3">Checkout Summary</h4>

            @if (Model == null || Model.Count == 0 || qtyMap.Count == 0)
            {
                <div class="alert alert-info">Your cart is empty.</div>

                <a class="btn btn-dark"
                   asp-controller="FoodItems"
                   asp-action="Browse">
                    Browse Items
                </a>
            }
            else
            {
                foreach (var item in Model)
                {
                    var qty = qtyMap.ContainsKey(item.ItemId) ? qtyMap[item.ItemId] : 0;
                    if (qty <= 0) { continue; }

                    decimal mrp = item.ActualPrice;
                    decimal selling = item.SellingPrice > 0 ? item.SellingPrice : item.ActualPrice;

                    decimal discountPerUnit = mrp > selling ? (mrp - selling) : 0m;
                    decimal discountTotal = discountPerUnit * qty;
                    decimal lineTotal = selling * qty;

                    totalMrp += mrp * qty;
                    totalSelling += lineTotal;
                    totalDiscount += discountTotal;

                    var imgPath = string.IsNullOrWhiteSpace(item.ItemImagePath)
                    ? "/images/placeholder.png"
                    : item.ItemImagePath;

                    <div class="card shadow-sm mb-3">
                        <div class="card-body d-flex gap-3 align-items-center justify-content-between">

                            <div class="d-flex gap-3 align-items-center">
                                <img src="@Url.Content(imgPath)"
                                     alt="@item.ItemName"
                                     class="rounded"
                                     style="width:70px;height:70px;object-fit:cover;" />

                                <div>
                                    <div class="fw-semibold">@item.ItemName</div>
                                    <div class="small text-muted">Qty: @qty</div>

                                    @if (discountTotal > 0)
                                    {
                                        <div class="text-success small">
                                            Saved ₹@discountTotal
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="text-end">
                                <div class="fw-bold">₹@lineTotal</div>

                                @if (discountPerUnit > 0)
                                {
                                    <small class="text-muted text-decoration-line-through">
                                        ₹@(mrp* qty)
                                    </small>
                                }
                            </div>

                        </div>
                    </div>
                }
            }
        </div>

        <!-- RIGHT: BILL DETAILS -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 80px;">
                <div class="card-body">
                    <h5 class="mb-3">Bill Details</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (MRP)</span>
                        <strong>₹@totalMrp</strong>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Discount</span>
                        <strong class="text-success">- ₹@totalDiscount</strong>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between fs-5 fw-bold mb-3">
                        <span>To Pay</span>
                        <span>₹@totalSelling</span>
                    </div>

                    <form method="post" action="/cart/placeorder">
                        <button type="submit" class="btn btn-success w-100">Place Order</button>
                    </form>
                    
                    <div class="d-flex flex-column">
                        <a class="btn btn-link w-100 mt-2"
                           href="/cart/items">
                            ← Back to Cart
                        </a>
                        <a class="btn btn-dark mt-2" asp-controller="FoodItems" asp-action="Browse">Browse Items</a>
                        </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        async function placeOrder() {
            try {
                const res = await fetch('/cart/placeorder', { method: 'POST' });

                // Read raw response safely
                const text = await res.text();
                let j = null;
                try { j = JSON.parse(text); } catch { }

                if (res.status === 401) {
                    if (j && j.needLogin && j.loginUrl) window.location.href = j.loginUrl;
                    else alert("Please login again.");
                    return;
                }

                if (!res.ok) {
                    alert("HTTP Error: " + res.status + "\n" + (text || "No response body"));
                    return;
                }

                if (j && j.ok) {
                    alert("Order placed successfully! Order ID: " + j.orderId);
                    window.location.href = "/FoodItems/Browse";
                } else {
                    alert("Order failed: " + (j?.message || j?.error || text || "Unknown error"));
                }
            } catch (e) {
                alert("Order failed (client error): " + e);
            }
        }
    </script>
}