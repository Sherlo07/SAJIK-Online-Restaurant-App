@model OnlineRestaurantApp.Components.Category

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Edit</h1>

<h4>Category</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CategoryId" />
            <div class="form-group">
                <label asp-for="CategoryName" class="control-label"></label>
                <input asp-for="CategoryName" class="form-control" />
                <span asp-validation-for="CategoryName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryDescritpion" class="control-label"></label>
                <textarea asp-for="CategoryDescritpion" class="form-control" rows="10" cols="100"></textarea>
                <span asp-validation-for="CategoryDescritpion" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CategoryImage" class="control-label"></label>
                <img src="@Model.CategoryImagePath" width="300" height="225" />
            </div>
            <div class="form-group">
                <label asp-for="CategoryImage" class="control-label"></label>
                <img src="" id="prevImage" width="300" height="225"/>
            </div>
            
            <div class="form-group">
                <label asp-for="CategoryImage" class="control-label"></label>
                <input type="file" asp-for="CategoryImage" class="form-control" onchange="preview(event)"/>
                <span asp-validation-for="CategoryImage" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CategoryStatus" /> @Html.DisplayNameFor(model => model.CategoryStatus)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="CategoryDiscount" class="control-label"></label>
                <input asp-for="CategoryDiscount" class="form-control" />
                <span asp-validation-for="CategoryDiscount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="hidden" asp-for="CategoryImagePath"/>
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

<script type="text/javascript">
    function preview(event)
    {
        var refImg=document.getElementById("prevImage");
        refImg.src=URL.createObjectURL(event.target.files[0]);
    }
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
