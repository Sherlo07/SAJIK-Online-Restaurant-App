@model List<OnlineRestaurantApp.Components.Payment>

@{

    ViewData["Title"] = "My Payments";
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";

}

<div class="container py-4">
    <h3 class="mb-3">My Payments</h3>

    @if (Model == null || Model.Count == 0)

    {
        <div class="alert alert-info">No payments found.</div>

    }

    else

    {
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Paid On</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var p in Model)

                            {
                                <tr>
                                    <td class="fw-semibold">#@p.OrderId</td>
                                    <td>@p.PaidOnDate.("dd-MMM-yyyy hh:mm tt")</td>
                                    <td>₹ @p.OrderAmount.ToString("0.00")</td>
                                    <td>

                                        @if (p.Status)

                                        {
                                            <span class="badge bg-success">Success</span>

                                        }

                                        else

                                        {
                                            <span class="badge bg-danger">Failed</span>

                                        }
                                    </td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="/payment/success/@p.OrderId">

                                            View Order
                                        </a>
                                    </td>
                                </tr>

                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    }
</div>
