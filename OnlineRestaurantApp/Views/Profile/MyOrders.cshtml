@model List<OnlineRestaurantApp.Components.Order>

@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
}

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Page Header -->
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h3 class="fw-bold mb-0">My Orders</h3>
                <span class="text-muted small">
                    @Model?.Count ?? 0 orders
                </span>
            </div>

            @if (Model == null || !Model.Any())
            {
                <!-- Empty State -->
                <div class="alert alert-info shadow-sm">
                    <i class="bi bi-bag-x me-1"></i>
                    You haven't placed any orders yet.
                    <a asp-controller="FoodItems" asp-action="Browse" class="alert-link ms-1">
                        Start ordering →
                    </a>
                </div>
            }
            else
            {
                <!-- Orders Card -->
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-0">

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Order #</th>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th class="text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @foreach (var o in Model)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold">
                                                #@o.OrderId
                                            </td>

                                            <td class="text-muted">
                                                @o.OrderDate.ToString("dd-MMM-yyyy hh:mm tt")
                                            </td>

                                            <td class="fw-semibold">
                                                ₹ @o.OrderAmount.ToString("0.00")
                                            </td>

                                            <td class="text-end pe-4">
                                                <a class="btn btn-sm btn-outline-primary rounded-pill px-3"
                                                   href="/payment/success/@o.OrderId">
                                                    <i class="bi bi-eye me-1"></i>
                                                    View Details
                                                </a>
                                            </td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <!-- Info Hint -->
                <div class="alert alert-secondary small mt-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Click <b>View Details</b> to track delivery status, payment confirmation, and order items.
                </div>
            }

        </div>
    </div>
</div>