@model IEnumerable<OnlineRestaurantApp.Components.Slider>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Create New
    </a>
</p>

<table class="table table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SliderText)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SliderTextLink)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SliderOrderNo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedOn)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                Slider Image
            </th>
            <th class="text-center" style="width: 240px;">
                Actions
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.SliderText)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SliderTextLink)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SliderOrderNo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CreatedOn)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>
                <td>
                    <img src="@item.SliderImagePath" width="300" height="225" class="img-thumbnail" />
                </td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.SliderId" class="btn btn-sm btn-warning me-1">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.SliderId" class="btn btn-sm btn-info me-1 text-white">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.SliderId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>