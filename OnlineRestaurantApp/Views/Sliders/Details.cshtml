@model OnlineRestaurantApp.Components.Slider

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>Slider</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SliderText)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SliderText)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SliderTextLink)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SliderTextLink)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SliderOrderNo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SliderOrderNo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedOn)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedOn)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            Slider Image
        </dt>
        <dd class = "col-sm-10">
            <img src="@Model.SliderImagePath" width="300" height="225"/>
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.SliderId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
