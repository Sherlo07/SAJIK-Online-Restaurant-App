@using OnlineRestaurantApp.Utility
@model PaginatedList<FoodItem>

@{
    ViewData["Title"] = "FoodItemsManagement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>
    Food Items Management (@ViewData["FilteredTotal"]@(
        (ViewData["CurrentFilter"] as string)?.Length > 0
        ? $" of {ViewData["OverallTotal"]}"
        : ""
        ))
</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>

    <form asp-action="Index" method="get" class="mt-3">

        <!-- ================= Row 1 : Search ================= -->
        <div class="row align-items-end mb-3">
            <div class="col-md-5">
                <label class="form-label">Find by name</label>
                <input type="text"
                       name="searchString"
                       value="@ViewData["CurrentFilter"]"
                       class="form-control"
                       placeholder="Search category..." />
            </div>

            <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary me-2">
                    Search
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    Back to Full List
                </a>
            </div>
        </div>

        <!-- ================= Row 2 : Filters ================= -->
        <div class="row align-items-end">

            <div class="col-md-3">
                <label class="form-label">Filter by Category</label>
                <select name="categoryId"
                        asp-items="ViewBag.CategoryList"
                        class="form-control">
                    <option value="">-- All Categories --</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Sort by Price</label>
                <select name="sortOrder" class="form-control">
                    <option value="">-- Select --</option>

                    <option value="price_asc"
                            selected="@(ViewData["CurrentSort"] as string == "price_asc")">
                        Low → High
                    </option>

                    <option value="price_desc"
                            selected="@(ViewData["CurrentSort"] as string == "price_desc")">
                        High → Low
                    </option>
                </select>
            </div>

            <div class="col-md-4">
                <button type="submit" class="btn btn-primary me-2">
                    Apply Filters
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Reset
                </a>
            </div>
        </div>

    </form>
</p>

<div>
    <h4>FoodItem</h4>

    @foreach (var item in Model)
    {
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                <!-- Sort by Item Name (preserve currentFilter & categoryId) -->
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["NameSort"]"
                   asp-route-currentFilter='@ViewData["CurrentFilter"]'
                   asp-route-categoryId='@ViewData["CurrentCategory"]'
                   asp-route-pageNumber="1"
                   class="btn btn-link p-0 align-baseline">
                    ItemName
                </a>
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.ItemName)
            </dd>

            <dt class="col-sm-2">
                <!-- Sort by Actual Price (toggle via PriceSort from controller if you added it) -->
                <a asp-action="Index"
                   asp-route-sortOrder='@((ViewData["PriceSort"] ?? "price_asce").ToString())'
                   asp-route-currentFilter='@ViewData["CurrentFilter"]'
                   @*asp-route-categoryId='@ViewData["CurrentCategory"]'*@
                   asp-route-pageNumber="1"
                   class="btn btn-link p-0 align-baseline">
                    @Html.DisplayNameFor(model => item.ActualPrice)
                </a>
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.ActualPrice)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.Rating)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.Rating)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.RatingBy)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.RatingBy)
            </dd>

            <dt class="col-sm-2">
                Item Image
            </dt>
            <dd class="col-sm-10">
                <img src="@item.ItemImagePath" width="170" height="160" class="img-thumbnail" />
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.ItemDescription)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.ItemDescription)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsAvailable)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsAvailable)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsBestSeller)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsBestSeller)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsBreakFast)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsBreakFast)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsLunch)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsLunch)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsSnack)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsSnack)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsDinner)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsDinner)
            </dd>

            <dt class="col-sm-2">
                <!-- Sort by Discount (preserve filters) -->
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["DiscountSort"]"
                   asp-route-currentFilter='@ViewData["CurrentFilter"]'
                   @*asp-route-categoryId='@ViewData["CurrentCategory"]'*@
                   asp-route-pageNumber="1"
                   class="btn btn-link p-0 align-baseline">
                    Discount
                </a>
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.DiscountPer)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.SellingPrice)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.SellingPrice)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.IsFastMoving)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.IsFastMoving)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.Category)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.Category.CategoryDescritpion)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(modelItem => item.ItemType)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(modelItem => item.ItemType.ItemTypeName)
            </dd>
            <dd class="">
                <a asp-action="Edit" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-warning me-1">
                    Edit
                </a>
                <a asp-action="Details" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-info me-1">
                    Details
                </a>
                <a asp-action="Delete" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-danger">
                    Delete
                </a>
            </dd>
        </dl>
    }
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<div class="d-flex align-items-center justify-content-center gap-3">
    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-outline-secondary @prevDisabled">
        Previous
    </a>

    <span class="fw-semibold"> @Model.PageIndex / @Model.TotalPages </span>

    <a asp-action="Index"
       asp-route-sortOrder="@ViewData["CurrentSort"]"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-currentFilter="@ViewData["CurrentFilter"]"
       class="btn btn-outline-secondary @nextDisabled">
        Next
    </a>
</div>