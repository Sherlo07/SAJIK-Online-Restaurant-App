@model OnlineRestaurantApp.Components.User

@{

    ViewData["Title"] = "Register";

    Layout = "~/Views/Shared/_LoginLayout.cshtml";

}

<style>

    /* Small, safe UI polish (no logic impact) */

    .auth-wrap {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        background: radial-gradient(1200px circle at 10% 10%, rgba(13,110,253,.10), transparent 40%), radial-gradient(900px circle at 90% 30%, rgba(32,201,151,.10), transparent 35%), #f8fafc;
    }

    .auth-card {
        border: 0;
        border-radius: 1rem;
        overflow: hidden;
    }

        .auth-card .card-header {
            border: 0;
            padding: 1.25rem 1.5rem;
            background: linear-gradient(135deg, #0d6efd, #20c997);
        }

        .auth-card .card-body {
            padding: 1.5rem;
        }

    .form-control:focus {
        box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
        border-color: rgba(13,110,253,.6);
    }

    .divider {
        height: 1px;
        background: rgba(0,0,0,.08);
        margin: 1rem 0 1.25rem;
    }
</style>

<div class="auth-wrap">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-7 col-xl-6">

                <div class="card shadow-lg auth-card">
                    <div class="card-header text-white">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h3 class="mb-0 fw-semibold">Create your account</h3>
                                <small class="opacity-75">Join and start ordering in minutes</small>
                            </div>
                            <span class="badge bg-light text-dark rounded-pill px-3 py-2">

                                Register
                            </span>
                        </div>
                    </div>

                    <div class="card-body">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" role="alert"></div>

                        <form asp-action="RegisterUser" method="post" class="needs-validation" novalidate>
                            <div class="row g-3">
                                <!-- First + Last name in two columns -->
                                <div class="col-md-6">
                                    <label asp-for="UserFirstName" class="form-label fw-medium"></label>
                                    <input asp-for="UserFirstName" class="form-control" placeholder="Enter first name" />
                                    <span asp-validation-for="UserFirstName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="UserLastName" class="form-label fw-medium"></label>
                                    <input asp-for="UserLastName" class="form-control" placeholder="Enter last name" />
                                    <span asp-validation-for="UserLastName" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Email" class="form-label fw-medium"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">@@</span>
                                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Mobile" class="form-label fw-medium"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">+91</span>
                                        <input asp-for="Mobile" class="form-control" placeholder="Mobile number" />
                                    </div>
                                    <span asp-validation-for="Mobile" class="text-danger small"></span>
                                </div>

                                <!-- Password + Confirm password -->
                                <div class="col-md-6">
                                    <label asp-for="Password" class="form-label fw-medium"></label>
                                    <input type="password" asp-for="Password" class="form-control" placeholder="Create password" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                                    <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>

                                <!-- Role -->
                                <div class="col-12">
                                    <label class="form-label fw-medium">Role</label>
                                    <input type="hidden" asp-for="RoleId" />
                                    <input type="text" class="form-control bg-light" value="@ViewBag.defaultRole" readonly />
                                    <div class="form-text">Role is assigned automatically.</div>
                                </div>
                            </div>

                            <div class="divider"></div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">

                                    Create Account
                                </button>
                                <a asp-action="Login" class="btn btn-outline-secondary">

                                    Already have an account? Sign in
                                </a>
                            </div>

                            <p class="text-muted small mt-3 mb-0 text-center">

                                By creating an account, you agree to our
                                <a href="#" class="text-decoration-none">Terms</a> &amp;
                                <a href="#" class="text-decoration-none">Privacy Policy</a>.
                            </p>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <small class="text-muted">© @DateTime.UtcNow.Year OnlineRestaurantApp</small>
                </div>
            </div>
        </div>
    </div>
</div>
