@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-success bg-gradient text-white text-center py-4">
                        <div class="mb-2">
                            <i class="bi bi-key-fill fs-1"></i>
                        </div>
                        <h4 class="fw-semibold mb-0">Reset Password</h4>
                        <p class="small opacity-75 mb-0">Enter your new password below</p>
                    </div>

                    <div class="card-body p-4">
                        <!-- If you add server-side errors via ModelState.AddModelError("", "...") they will appear here -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                        <form asp-action="ResetPasswordUser" method="post">
                            @Html.AntiForgeryToken()

                            <!-- Keep your hidden email contract -->
                            <input type="hidden" name="email" value="@ViewBag.Email" />

                            <div class="mb-3">
                                <label for="newPassword" class="form-label fw-semibold">New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="••••••••" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="confirmPassword" class="form-label fw-semibold">Confirm New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-lock-fill"></i></span>
                                    <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="••••••••" required />
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg rounded-3 fw-semibold">
                                    Reset Password
                                </button>
                                <a asp-controller="User" asp-action="Login" class="btn btn-outline-secondary rounded-3">
                                    Back to Login
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center text-muted small mt-3">
                    © @DateTime.UtcNow.Year Online Restaurant
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}