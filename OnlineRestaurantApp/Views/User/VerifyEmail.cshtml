@model OnlineRestaurantApp.Components.User

@{
    ViewData["Title"] = "Verify Email";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-info bg-gradient text-dark text-center py-4">
                        <div class="mb-2">
                            <i class="bi bi-envelope-check fs-1"></i>
                        </div>
                        <h4 class="fw-semibold mb-0">Verify Email</h4>
                        <p class="small opacity-75 mb-0">Confirm your email address to proceed</p>
                    </div>

                    <div class="card-body p-4">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                        <form asp-action="VerifyEmail" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-info btn-lg rounded-3 text-dark fw-semibold">
                                    Verify
                                </button>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-3">
                                    Back
                                </a>
                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center text-muted small mt-3">
                    © @DateTime.UtcNow.Year Online Restaurant
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}