@{
    ViewData["Title"] = "Home Page";
}

<div class="container my-5">
    <div class="row align-items-center">
        <div class="col-md-7">
            <h1 class="display-4 fw-bold text-dark">Welcome to Sajik Restaurant</h1>
            <p class="lead border-start border-4 border-danger ps-3 mt-3 text-muted" style="font-style: italic;">
                Experience the authentic flavors of tradition. From our kitchen to your table,
                we serve freshly prepared dishes crafted with the finest ingredients and
                a dash of culinary passion.
            </p>
        </div>

        <div class="col-md-5 text-center">
            <img src="~/images/Hero/Sajik Image.jpg"
                 class="img-fluid rounded-4 shadow-lg"
                 alt="Sajik Restaurant Menu"
                 style="max-width: 50%;" />
        </div>
    </div>
</div>
